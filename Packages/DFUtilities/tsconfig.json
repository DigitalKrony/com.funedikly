{
  "extends": "../../common/config/typescript/tsconfig.json",
  "compilerOptions": {
    "target":"esnext",
    "outDir": "lib",
    "rootDir": "src",
    "types": ["node"],

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "useUnknownInCatchVariables": false,

    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "typeRoots": ["node_modules/@types"],
  "include": ["./src/**/*"],
  "exclude": ["lib", "lib-cjs", "node_modules"]
}
